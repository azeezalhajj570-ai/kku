---
import ArticleLayout from "../layouts/ArticleLayout.astro";
import Callout from "../components/Callout.astro";
---

<ArticleLayout
  title="جامعة الملك خالد"
  description="صفحة تعريفية مختصرة تحافظ على مضمون الصفحة الرئيسية القديمة ضمن الهيكل الجديد."
  summary="الصفحة القديمة كانت تجمع تعريفاً سريعاً بالجامعة مع روابط الموقع. هنا أصبحت صفحة تعريفية مستقلة، بينما تؤدي الصفحة الرئيسية الجديدة دور البوابة العملية."
  breadcrumbs={[
    { href: "/", label: "الرئيسية" },
    { href: "/kku", label: "عن الجامعة" }
  ]}
  metadata={[
    { label: "التصنيف", value: "صفحة تعريفية" },
    { label: "الأصل", value: "KKU.html" },
    { label: "آخر مراجعة", value: "21 أبريل 2026" }
  ]}
>
  <section>
    <h2>نبذة مختصرة</h2>
    <p>
      جامعة الملك خالد جامعة حكومية مقرها في مدينة أبها جنوب غربي المملكة العربية السعودية،
      وتأسست عام 1998م الموافق 1419هـ بعد دمج فرعي جامعة الإمام محمد بن سعود الإسلامية
      وجامعة الملك سعود في منطقة عسير تحت مسمى جامعة الملك خالد.
    </p>
  </section>

  <Callout title="موقع مستقل">
    هذا الدليل لا يمثل جهة رسمية. إذا كنت تبحث عن الأنظمة النهائية أو الإعلانات الملزمة فارجع إلى
    الموقع الرسمي للجامعة، ثم عد هنا لاستخدام الأدوات والملخصات والتنقل السريع بين الصفحات.
  </Callout>
</ArticleLayout>
