---
import BaseLayout from "./BaseLayout.astro";
import PageShell from "../components/PageShell.astro";
import Hero from "../components/Hero.astro";

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  summary: string;
}

const { title, description, eyebrow, summary } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageShell>
    <Hero eyebrow={eyebrow} title={title} summary={summary} />
    <slot />
  </PageShell>
</BaseLayout>
